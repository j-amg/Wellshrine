// FloatOp:4
	float n_out4p0 = n_out2p2 + n_out10p0;


// VectorCompose:5
	vec2 n_out5p0 = vec2(n_out12p0, n_out4p0);


	vec4 n_out7p0;
// Texture2D:7
	n_out7p0 = texture(Texture2DParameter, n_out5p0);


// Input:13
	vec2 n_out13p0 = UV;
	float n_out13p1 = n_out13p0.r;
	float n_out13p2 = n_out13p0.g;


// FloatOp:20
	float n_in20p1 = -1.00000;
	float n_out20p0 = n_out13p1 * n_in20p1;


// FloatParameter:15
	float n_out15p0 = FloatParameter2;


// FloatOp:16
	float n_out16p0 = n_out3p0 * n_out15p0;


// FloatOp:19
	float n_out19p0 = n_out20p0 + n_out16p0;


// FloatOp:21
	float n_in21p1 = -1.00000;
	float n_out21p0 = n_out13p2 * n_in21p1;


// FloatOp:17
	float n_out17p0 = n_out21p0 + n_out16p0;


// VectorCompose:18
	vec2 n_out18p0 = vec2(n_out19p0, n_out17p0);


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Texture2DParameter, n_out18p0);


// Mix:6
	float n_in6p2 = 0.50000;
	vec3 n_out6p0 = mix(vec3(n_out7p0.xyz), vec3(n_out8p0.xyz), n_in6p2);


// FloatOp:14
	float n_in14p1 = 0.50000;
	float n_out14p0 = n_out6p0.x * n_in14p1;


// Output:0
	EMISSION = vec3(n_out14p0);


}
