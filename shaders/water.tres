code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, ambient_light_disabled;

uniform float FloatParameter = 0.05000000074506;
uniform sampler2D Texture2DParameter : filter_nearest;
uniform float FloatParameter2 = -0.02500000037253;



void fragment() {
// Input:2
	vec2 n_out2p0 = UV;
	float n_out2p1 = n_out2p0.r;
	float n_out2p2 = n_out2p0.g;


// Input:3
	float n_out3p0 = TIME;


// FloatParameter:11
	float n_out11p0 = FloatParameter;


// FloatOp:10
	float n_out10p0 = n_out3p0 * n_out11p0;


// FloatOp:12
