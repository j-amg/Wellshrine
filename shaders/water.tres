code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, ambient_light_disabled;

uniform float FloatParameter = 0.05000000074506;
uniform sampler2D Texture2DParameter : filter_nearest;



void fragment() {
// Input:2
	vec2 n_out2p0 = UV;
	float n_out2p1 = n_out2p0.r;
	float n_out2p2 = n_out2p0.g;


// Input:3
	float n_out3p0 = TIME;


// FloatParameter:11
	float n_out11p0 = FloatParameter;


// FloatOp:10
	float n_out10p0 = n_out3p0 * n_out11p0;


// FloatOp:12
	float n_out12p0 = n_out2p1 + n_out10p0;


// FloatOp:4
	float n_out4p0 = n_out2p2 + n_out10p0;


// VectorCompose:5
	vec2 n_out5p0 = vec2(n_out12p0, n_out4p0);


	vec4 n_out7p0;
// Texture2D:7
	n_out7p0 = texture(Texture2DParameter, n_out5p0);


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Texture2DParameter, UV);


// Mix:6
	float n_in6p2 = 0.50000;
	vec3 n_out6p0 = mix(vec3(n_out7p0.xyz), vec3(n_out8p0.xyz), n_in6p2);


// FloatOp:14
	float n_in14p1 = 0.50000;
	float n_out14p0 = n_out6p0.x * n_in14p1;


// Output:0
	EMISSION = vec3(n_out14p0);


}
